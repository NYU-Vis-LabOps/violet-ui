{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "violet-select",
  "type": "registry:ui",
  "title": "Violet Select",
  "description": "NYU select dropdown with purple focus ring",
  "dependencies": [
    "radix-ui"
  ],
  "registryDependencies": [
    "https://nyu-vis-labops.github.io/violet-ui/r/styles/violet-theme.json",
    "https://nyu-vis-labops.github.io/violet-ui/r/lib/violet-utils.json"
  ],
  "files": [
